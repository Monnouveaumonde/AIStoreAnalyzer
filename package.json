{
  "name": "ai-store-analyzer",
  "version": "1.0.0",
  "private": true,
  "description": "Shopify App - AI Store Analyzer: Analyse complète de boutiques Shopify avec scoring IA",
  "scripts": {
    "build": "remix vite:build",
    "dev": "shopify app dev",
    "docker-start": "npm run setup && npm run start",
    "generate": "shopify app generate",
    "deploy": "shopify app deploy",
    "setup": "prisma generate && prisma migrate deploy",
    "start": "HOST=0.0.0.0 remix-serve ./build/server/index.js",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "shopify": "shopify",
    "prisma": "prisma",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "db:test": "npx tsx prisma/test-connection.ts",
    "test": "vitest"
  },
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@prisma/extension-accelerate": "^1.3.0",
    "@remix-run/dev": "^2.11.0",
    "@remix-run/node": "^2.11.0",
    "@remix-run/react": "^2.11.0",
    "@remix-run/serve": "^2.11.0",
    "@shopify/app-bridge-react": "^4.1.2",
    "@shopify/polaris": "^13.9.0",
    "@shopify/shopify-app-remix": "^3.2.0",
    "@shopify/shopify-app-session-storage-prisma": "^3.0.0",
    "cheerio": "^1.0.0",
    "html-pdf-node": "^1.0.8",
    "isbot": "^5.1.14",
    "node-cron": "^3.0.3",
    "openai": "^4.56.0",
    "prisma": "^5.22.0",
    "puppeteer-core": "^23.3.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite-tsconfig-paths": "^5.0.1"
  },
  "devDependencies": {
    "@remix-run/eslint-config": "^2.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "eslint": "^8.57.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
