# ============================================
# SHOPIFY APP — Variables obligatoires
# ============================================

# Clés Shopify (depuis partners.shopify.com)
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret

# Scopes OAuth nécessaires
SCOPES=read_content,read_discounts,read_orders,read_price_rules,read_products,read_themes

# URL publique de l'app (ngrok en dev, Vercel en prod)
HOST=https://your-app-url.vercel.app
SHOPIFY_APP_URL=https://your-app-url.vercel.app
APP_URL=https://your-app-url.vercel.app

# ============================================
# BASE DE DONNÉES PostgreSQL
# ============================================

# Format local (développement)
# DATABASE_URL=postgresql://postgres:password@localhost:5432/ai_store_analyzer

# Prisma Data Platform (actuellement configuré dans .env)
# DATABASE_URL="postgres://TOKEN:SK@db.prisma.io:5432/postgres?sslmode=require"

# Pour Railway :
# DATABASE_URL=postgresql://user:password@host.railway.app:5432/railway

# Pour Supabase :
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres?sslmode=require

# Pour Neon :
# DATABASE_URL=postgresql://[USER]:[PASS]@[HOST].neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://postgres:password@localhost:5432/ai_store_analyzer

# ============================================
# IA — Génération de coaching personnalisé
# ============================================

# Choisir le provider: "openai" ou "anthropic"
AI_PROVIDER=openai

# OpenAI (GPT-4o-mini recommandé pour le coût)
OPENAI_API_KEY=sk-...

# Anthropic (Claude 3.5 Sonnet)
ANTHROPIC_API_KEY=sk-ant-...

# ============================================
# PERFORMANCE — APIs optionnelles
# ============================================

# Google PageSpeed Insights API (gratuit, 25k req/jour)
# Obtenir sur: https://console.cloud.google.com/
GOOGLE_PAGESPEED_API_KEY=AIza...

# ============================================
# ENVIRONNEMENT
# ============================================

NODE_ENV=development
# NODE_ENV=production  # En production
